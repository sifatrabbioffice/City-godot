; Engine configuration file — Massive City (GTA5/RDR2 Scale)
; Godot 4.5 — Jolt Physics — Vulkan Forward+
config_version=5

[application]

config/name="Massive City"
config/description="GTA5/RDR2-scale procedural open world"
run/main_scene="res://world.tscn"
config/features=PackedStringArray("4.5", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"

